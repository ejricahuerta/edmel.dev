# https://resend.com/api-keys
RESEND_API_KEY=re_xxxxxxxx

# Inbox that receives contact form submissions
CONTACT_EMAIL=you@example.com

# Must be a verified sender/domain in Resend (e.g. "Edmel <hello@yourdomain.com>").
# Use your own domain in Resend (SPF/DKIM) — shared onboarding@resend.dev often hits spam.
RESEND_FROM="Edmel <hello@yourdomain.com>"
